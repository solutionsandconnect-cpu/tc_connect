rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Utilisateur connecté ayant le rôle Admin (le freelance)
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_app == 'Admin';
    }

    // Factures & devis : accès au PROPRIÉTAIRE (le freelance, via userId),
    // à l'ADMIN, et en LECTURE au client rattaché (clientLinkedUserId).
    // L'espace client public passe par l'Admin SDK (serveur) et n'est pas concerné.
    match /factures/{document} {
      allow read: if request.auth != null && (
        isAdmin()
        || resource.data.userId == request.auth.uid
        || resource.data.clientLinkedUserId == request.auth.uid
      );
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    // factureItems : collection résiduelle (aucun accès client) — fermée aux connectés.
    match /factureItems/{document} {
      allow read, create, update, delete: if request.auth != null;
    }

    match /clients/{docId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    match /companies/{document} {
      allow read: if true;
      allow create, write, delete: if request.auth != null;
    }

    match /abonnements/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Parcours Sportif — séances publiques
    match /sessions/{document} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /registrations/{document} {
      allow read, create, delete: if true;
      allow update: if true;
    }

    // Contenu de séance (circuits/exercices) — réservé aux admins authentifiés
    match /session_content/{document} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }

    // Avis Parcours Sportif — lecture et dépôt public.
    // Suppression : par un admin, OU par l'utilisateur connecté dont l'email
    // correspond à celui enregistré sur l'avis.
    match /parcours_reviews/{document} {
      allow read, create: if true;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_app == 'Admin'
        || (resource.data.email is string && resource.data.email == request.auth.token.email)
      );
    }

    match /activites_clients/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /shared_documents/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /push_subscriptions/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /notes_historique/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if true;
      allow delete: if true;
    }

    // Notes sur les participants du Parcours Sportif (admin) — y compris paiements anticipés
    match /parcours_notes/{document} {
      allow create, read, write, delete: if request.auth != null;
    }

    // Indications / alertes du Parcours Sportif — lecture publique (page visiteur), écriture admin
    match /parcours_indications/{document} {
      allow read: if true;
      allow create, write, delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_app == 'Admin';
    }

    // Pilotage de l'activité (contrats clients, MRR, marge) — réservé à l'admin
    match /pilotage_contrats/{document} {
      allow read, create, write, delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_app == 'Admin';
    }

    // Catalogue de briques de fonctionnalités (estimateur de tarif) — réservé à l'admin
    match /pilotage_catalogue/{document} {
      allow read, create, write, delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_app == 'Admin';
    }

    // Réglages du Pilotage (valeurs par défaut du calculateur) — réservé à l'admin
    match /pilotage_settings/{document} {
      allow read, create, write, delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_app == 'Admin';
    }

    // Documents projet & contrats légaux reliés à un contrat — réservé à l'admin
    match /pilotage_documents/{document} {
      allow read, create, write, delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_app == 'Admin';
    }

    // Immobilisations / matériel à amortir (Pilotage) — réservé à l'admin
    match /pilotage_immobilisations/{document} {
      allow read, create, write, delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_app == 'Admin';
    }

    match /database_users_details/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /Notifications/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if true;
      allow delete: if true;
    }

    match /app_config/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if true;
      allow delete: if true;
    }

    match /seance/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /exercices/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /programme_seance/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /exercice_memory/{document} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ─── Belote (accès partagé entre utilisateurs connectés) ───────────────────
    // Données privées à chaque utilisateur : créateur OU admin (admin pour le nettoyage à l'archivage)
    match /belote_teams/{document} {
      allow read, update, delete: if request.auth != null && (
        resource.data.createdBy == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_app == 'Admin'
      );
      allow create: if request.auth != null && request.resource.data.createdBy == request.auth.uid;
    }
    match /belote_games/{document} {
      allow read, update, delete: if request.auth != null && (
        resource.data.createdBy == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_app == 'Admin'
      );
      allow create: if request.auth != null && request.resource.data.createdBy == request.auth.uid;
    }
    // Tours : liés à une partie ; accès authentifié (toujours consultés via une partie possédée)
    match /belote_rounds/{document} {
      allow read, write, delete: if request.auth != null;
    }

    match /inviteLinks/{token} {
      // Lecture pour tout utilisateur authentifié (le token fait office de secret)
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;
    }

    match /trips/{tripId} {
      // Lecture/modification réservées aux membres (owner inclus dans memberIds)
      allow read: if request.auth != null
        && request.auth.uid in resource.data.memberIds;
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.memberIds;
      // Seul le propriétaire peut supprimer
      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }

    match /planning_pro/{document} {
      allow create: if request.auth != null;
      allow read: if true;
      allow write: if true;
      allow delete: if request.auth != null;
    }

    match /rpe/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /calendrier_team/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /seances_equipe/{document} {
      allow create: if request.auth != null;
      allow read: if true;
      allow write: if true;
      allow delete: if request.auth != null;
    }

    match /joueurs/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /team/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /users/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /user_prestations/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /store_apps/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_app == 'Admin';
    }

    match /babies/{babyId} {
      // Le partage entre co-parents repose sur le tableau `members` (liste d'UID).
      function isBabyMember() {
        return request.auth != null && request.auth.uid in resource.data.members;
      }

      // Création : on doit se mettre soi-même dans members (pas de bébé créé au nom d'un tiers)
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.members
        && request.resource.data.createdBy == request.auth.uid;

      allow read: if isBabyMember() || isAdmin();

      // Modification : un membre édite le suivi, mais ne peut toucher NI à la liste des
      // membres NI au créateur. Inviter / retirer un co-parent passe uniquement par
      // l'Admin SDK (routes /api/bebe-invite), donc jamais par le client.
      allow update: if (
          isBabyMember()
          && request.resource.data.members == resource.data.members
          && request.resource.data.get('createdBy', '') == resource.data.get('createdBy', '')
        ) || isAdmin();

      // Suppression : le créateur seul (un co-parent invité « quitte le partage » à la place,
      // sinon il effacerait les données de tout le monde). Les bébés créés avant le partage
      // n'ont pas toujours `createdBy` → repli sur le membre qui demande.
      allow delete: if (
          isBabyMember()
          && resource.data.get('createdBy', request.auth.uid) == request.auth.uid
        ) || isAdmin();

      match /events/{eventId} {
        // Les events héritent de l'accès au document bébé parent
        allow read, write, delete: if isAdmin() || (request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/babies/$(babyId)).data.members);
      }

      match /contacts/{contactId} {
        // Les contacts d'annonce héritent de l'accès au document bébé parent
        allow read, write, delete: if isAdmin() || (request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/babies/$(babyId)).data.members);
      }
    }

    match /store_reviews/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // L'auteur modifie/supprime son avis ; l'Admin peut supprimer n'importe quel avis
      allow update: if request.auth != null && resource.data.userUid == request.auth.uid;
      allow delete: if request.auth != null && (
        resource.data.userUid == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_app == 'Admin'
      );
    }

    match /store_subscriptions/{id} {
      allow read: if request.auth != null && (
        resource.data.userUid == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_app == 'Admin'
      );
      allow create: if request.auth != null;
      // Mise à jour : l'admin (tout) OU le titulaire UNIQUEMENT pour se désabonner
      // (passage en 'cancelled', sans pouvoir changer d'app ni se ré-attribuer la souscription).
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_app == 'Admin' ||
        (
          resource.data.userUid == request.auth.uid &&
          request.resource.data.statut == 'cancelled' &&
          request.resource.data.appId == resource.data.appId &&
          request.resource.data.userUid == resource.data.userUid
        )
      );
      // Suppression : réservée à l'admin (les utilisateurs n'effacent plus, on garde une trace).
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_app == 'Admin';
    }

    match /urssaf_periodes/{document} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null
        && (resource == null || resource.data.userId == request.auth.uid);
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    match /messagerie/{docId} {
      allow read, write: if request.auth != null;

      match /messages_messagerie/{msgId} {
        allow read, create, update: if request.auth != null;
      }
    }

    // Paramètres globaux de l'app (Parcours Sportif, etc.) — lecture publique, écriture admin
    match /settings/{document} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_app == 'Admin';
    }

    // Carnet des apps créées par le freelance (liens Vercel) — admin uniquement
    match /mes_apps/{document} {
      allow read, create, update, delete: if isAdmin();
    }

    // ── Mailing (prospection Enezo) ──
    // Ces collections contiennent des données personnelles de TIERS qui n'ont
    // pas de compte : elles sont strictement réservées à l'admin. La
    // désinscription publique passe par l'Admin SDK côté serveur et n'est donc
    // pas concernée par ces règles.
    match /prospects/{document} {
      allow read, create, update, delete: if isAdmin();
    }

    match /mailing_metiers/{document} {
      allow read, create, update, delete: if isAdmin();
    }

    // Archive des envois : jamais modifiée ni supprimée depuis le client, c'est
    // ce qui garantit qu'un message archivé reste le message réellement envoyé.
    match /mailing_envois/{document} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    // Registre d'opposition : jamais supprimable. Une opposition doit survivre
    // à la suppression du prospect comme au ré-import d'une liste.
    match /mailing_optout/{document} {
      allow read, create, update: if isAdmin();
      allow delete: if false;
    }

    // Journal du parcours des prospects (changements de statut, envois, notes).
    // Les NOTES sont des annotations personnelles : modifiables et supprimables.
    // Les FAITS (envoi, changement de statut, promotion) restent figés — c'est ce
    // qui donne sa valeur au journal si une opposition est contestée.
    // `resource.data` = document AVANT écriture, `request.resource.data` = APRÈS :
    // les deux sont vérifiés pour qu'un fait ne puisse pas être requalifié en note.
    match /mailing_evenements/{document} {
      allow read, create: if isAdmin();
      allow update: if isAdmin()
        && resource.data.type == 'note'
        && request.resource.data.type == 'note';
      allow delete: if isAdmin() && resource.data.type == 'note';
    }

    match /{document=**} {
      allow read, write: if request.auth.token.email.matches("firebase@flutterflow.io");
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
