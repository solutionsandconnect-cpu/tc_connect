rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /factures/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if true;
      allow delete: if true;
    }

    match /factureItems/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if true;
      allow delete: if true;
    }

    match /clients/{docId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    match /companies/{document} {
      allow read: if true;
      allow create, write, delete: if request.auth != null;
    }

    match /abonnements/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Parcours Sportif — séances publiques
    match /sessions/{document} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /registrations/{document} {
      allow read, create, delete: if true;
      allow update: if true;
    }

    // Contenu de séance (circuits/exercices) — réservé aux admins authentifiés
    match /session_content/{document} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }

    // Avis Parcours Sportif — lecture et dépôt public.
    // Suppression : par un admin, OU par l'utilisateur connecté dont l'email
    // correspond à celui enregistré sur l'avis.
    match /parcours_reviews/{document} {
      allow read, create: if true;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_app == 'Admin'
        || (resource.data.email is string && resource.data.email == request.auth.token.email)
      );
    }

    match /activites_clients/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /shared_documents/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /push_subscriptions/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /notes_historique/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if true;
      allow delete: if true;
    }

    match /database_users_details/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /Notifications/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if true;
      allow delete: if true;
    }

    match /app_config/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if true;
      allow delete: if true;
    }

    match /seance/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /exercices/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /programme_seance/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /exercice_memory/{document} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ─── Belote (accès partagé entre utilisateurs connectés) ───────────────────
    // Données privées à chaque utilisateur : créateur OU admin (admin pour le nettoyage à l'archivage)
    match /belote_teams/{document} {
      allow read, update, delete: if request.auth != null && (
        resource.data.createdBy == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_app == 'Admin'
      );
      allow create: if request.auth != null && request.resource.data.createdBy == request.auth.uid;
    }
    match /belote_games/{document} {
      allow read, update, delete: if request.auth != null && (
        resource.data.createdBy == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_app == 'Admin'
      );
      allow create: if request.auth != null && request.resource.data.createdBy == request.auth.uid;
    }
    // Tours : liés à une partie ; accès authentifié (toujours consultés via une partie possédée)
    match /belote_rounds/{document} {
      allow read, write, delete: if request.auth != null;
    }

    match /inviteLinks/{token} {
      // Lecture pour tout utilisateur authentifié (le token fait office de secret)
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;
    }

    match /trips/{tripId} {
      // Lecture/modification réservées aux membres (owner inclus dans memberIds)
      allow read: if request.auth != null
        && request.auth.uid in resource.data.memberIds;
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.memberIds;
      // Seul le propriétaire peut supprimer
      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }

    match /planning_pro/{document} {
      allow create: if request.auth != null;
      allow read: if true;
      allow write: if true;
      allow delete: if request.auth != null;
    }

    match /rpe/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /calendrier_team/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /seances_equipe/{document} {
      allow create: if request.auth != null;
      allow read: if true;
      allow write: if true;
      allow delete: if request.auth != null;
    }

    match /joueurs/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /team/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /users/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /user_prestations/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /store_apps/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_app == 'Admin';
    }

    match /babies/{babyId} {
      // Création libre (authentifié) ; lecture/modif/suppression réservées aux membres
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null
        && request.auth.uid in resource.data.members;

      match /events/{eventId} {
        // Les events héritent de l'accès au document bébé parent
        allow read, write, delete: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/babies/$(babyId)).data.members;
      }
    }

    match /store_reviews/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // L'auteur modifie/supprime son avis ; l'Admin peut supprimer n'importe quel avis
      allow update: if request.auth != null && resource.data.userUid == request.auth.uid;
      allow delete: if request.auth != null && (
        resource.data.userUid == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_app == 'Admin'
      );
    }

    match /store_subscriptions/{id} {
      allow read: if request.auth != null && (
        resource.data.userUid == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_app == 'Admin'
      );
      allow create: if request.auth != null;
      // Mise à jour : l'admin (tout) OU le titulaire UNIQUEMENT pour se désabonner
      // (passage en 'cancelled', sans pouvoir changer d'app ni se ré-attribuer la souscription).
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_app == 'Admin' ||
        (
          resource.data.userUid == request.auth.uid &&
          request.resource.data.statut == 'cancelled' &&
          request.resource.data.appId == resource.data.appId &&
          request.resource.data.userUid == resource.data.userUid
        )
      );
      // Suppression : réservée à l'admin (les utilisateurs n'effacent plus, on garde une trace).
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_app == 'Admin';
    }

    match /urssaf_periodes/{document} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    match /messagerie/{docId} {
      allow read, write: if request.auth != null;

      match /messages_messagerie/{msgId} {
        allow read, create, update: if request.auth != null;
      }
    }

    // Paramètres globaux de l'app (Parcours Sportif, etc.) — lecture publique, écriture admin
    match /settings/{document} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role_app == 'Admin';
    }

    match /{document=**} {
      allow read, write: if request.auth.token.email.matches("firebase@flutterflow.io");
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
