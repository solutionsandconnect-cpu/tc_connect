rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if false;
    }
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth.uid == userId;
    }
    // Images uploadées par un utilisateur connecté et affichées dans l'app :
    // exercices (photos d'exercice), avatars (photos de profil), teams (logos d'équipe).
    // Lecture publique (getDownloadURL juste après upload + affichage), écriture connectée,
    // images seules < 10 Mo.
    match /exercices/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }
    match /avatars/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }
    match /teams/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }
    // Certificats médicaux Parcours Sportif — upload public (inscription sans compte).
    // Lecture publique nécessaire car getDownloadURL() est appelé juste après l'upload
    // par un visiteur NON connecté (sinon l'URL ne peut pas être récupérée et le
    // certificat n'est jamais enregistré). L'accès reste protégé par le token aléatoire
    // de l'URL de téléchargement (non listable, non devinable). Limité aux PDF/images < 10 Mo.
    match /medical_certs/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType == 'application/pdf');
    }
    // Photos d'avis Parcours Sportif — lecture publique, upload public (images < 10 Mo)
    match /parcours_reviews/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}